@page "/coupons/delete"
@inject IGetCouponByIdUseCase GetCouponByIdUseCase
@inject IDeleteCouponUseCase DeleteCouponUseCase
@inject NavigationManager NavigationManager

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>
<div>
    <h2>Coupon</h2>
    <hr />
    @if (coupon is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Code</dt>
            <dd class="col-sm-10">@coupon.Code</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Discount</dt>
            <dd class="col-sm-10">@coupon.Discount</dd>
        </dl>
        <EditForm method="post" Model="coupon" OnValidSubmit="DeleteCoupon" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(coupon is null)">Delete</button> |
            <a href="/coupons">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private Coupon? coupon;

    [SupplyParameterFromQuery]
    private int Id { get; set; }

    protected override async Task OnParametersSetAsync()
    {
       
        coupon = await GetCouponByIdUseCase.ExecuteAsync(Id);

        if (coupon is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task DeleteCoupon()
    {
        await DeleteCouponUseCase.ExecuteAsync(Id);
        NavigationManager.NavigateTo("/coupons");
    }
}
