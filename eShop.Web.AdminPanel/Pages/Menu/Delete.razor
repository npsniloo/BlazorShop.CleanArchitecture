@page "/menus/delete"

@inject IGetMenuByIdUseCase GetMenuByIdUseCase
@inject IDeleteMenuUseCase DeleteMenuUseCase
@inject NavigationManager NavigationManager

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>
<div>
    <h2>Menu</h2>
    <hr />
    @if (menu is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">MenuTitle</dt>
            <dd class="col-sm-10">@menu.Title</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Link</dt>
            <dd class="col-sm-10">@menu.Link</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Type</dt>
            <dd class="col-sm-10">@menu.Type</dd>
        </dl>
        <EditForm method="post" Model="menu" OnValidSubmit="DeleteMenu" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(menu is null)">Delete</button> |
            <a href="/menus">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private Menu? menu;

    [SupplyParameterFromQuery]
    private int Id { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        menu = await GetMenuByIdUseCase.ExecuteAsync(Id);

        if (menu is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task DeleteMenu()
    {
        await DeleteMenuUseCase.ExecuteAsync(Id);
        NavigationManager.NavigateTo("/menus");
    }
}
