@page "/users/delete"

@inject IGetUserByIdUseCase GetUserByIdUseCase
@inject IDeleteUserUseCase DeleteUserUseCase
@inject NavigationManager NavigationManager

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>
<div>
    <h2>User</h2>
    <hr />
    @if (user is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Email</dt>
            <dd class="col-sm-10">@user.Email</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">FullName</dt>
            <dd class="col-sm-10">@user.FullName</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">IsAdmin</dt>
            <dd class="col-sm-10">@user.IsAdmin</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">RegisterDate</dt>
            <dd class="col-sm-10">@user.RegisterDate</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">RecoveryCode</dt>
            <dd class="col-sm-10">@user.RecoveryCode</dd>
        </dl>
        <EditForm method="post" Model="user" OnValidSubmit="DeleteUser" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(user is null)">Delete</button> |
            <a href="/users">Back to List</a>
        </EditForm>
    }
</div>

@code {

    private User? user;

    [SupplyParameterFromQuery]
    private int Id { get; set; }

    protected async override Task OnParametersSetAsync()
    {
        user = await GetUserByIdUseCase.ExecuteAsync(Id);

        if (user is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task DeleteUser()
    {
        await DeleteUserUseCase.ExecuteAsync(user!.Id);
        
        NavigationManager.NavigateTo("/users");
    }
}
