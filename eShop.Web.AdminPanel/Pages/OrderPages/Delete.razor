@page "/orders/delete"
@inject IGetOrderByIdUseCase GetOrderByIdUseCase
@inject IDeleteOrderUseCase DeleteOrderUseCase
@inject NavigationManager NavigationManager

<PageTitle>Delete</PageTitle>

<h1>Delete Order</h1>

<p>Are you sure you want to delete this?</p>
<div>
    <hr />
    @if (order is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">UserId</dt>
            <dd class="col-sm-10">@order.UserId</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">FirstName</dt>
            <dd class="col-sm-10">@order.FirstName</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">LastName</dt>
            <dd class="col-sm-10">@order.LastName</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">CompanyName</dt>
            <dd class="col-sm-10">@order.CompanyName</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Country</dt>
            <dd class="col-sm-10">@order.Country</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">City</dt>
            <dd class="col-sm-10">@order.City</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Address</dt>
            <dd class="col-sm-10">@order.Address</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Email</dt>
            <dd class="col-sm-10">@order.Email</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Phone</dt>
            <dd class="col-sm-10">@order.Phone</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Comment</dt>
            <dd class="col-sm-10">@order.Comment</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">CouponCode</dt>
            <dd class="col-sm-10">@order.CouponCode</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">CouponDiscount</dt>
            <dd class="col-sm-10">@order.CouponDiscount</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Shipping</dt>
            <dd class="col-sm-10">@order.Shipping</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">SubTotal</dt>
            <dd class="col-sm-10">@order.SubTotal</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Total</dt>
            <dd class="col-sm-10">@order.Total</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">CreateDate</dt>
            <dd class="col-sm-10">@order.CreateDate</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">TransactionId</dt>
            <dd class="col-sm-10">@order.TransactionId</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">TransactionStatus</dt>
            <dd class="col-sm-10">@order.TransactionStatus</dd>
        </dl>
        <EditForm method="post" Model="order" OnValidSubmit="DeleteOrder" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(order is null)">Delete</button> |
            <a href="/orders">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private Order? order;

    [SupplyParameterFromQuery]
    private int Id { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        order = await GetOrderByIdUseCase.ExecuteAsync(Id);

        if (order is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task DeleteOrder()
    {
        await DeleteOrderUseCase.ExecuteAsync(Id);
        NavigationManager.NavigateTo("/orders");
    }
}
