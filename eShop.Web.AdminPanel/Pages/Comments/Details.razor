@page "/comments/details"
@inject NavigationManager NavigationManager
@inject IGetCommentByIdUseCase GetCommentByIdUseCase

<PageTitle>Details</PageTitle>

<h1>Details</h1>

<div>
    <h2>Comment</h2>
    <hr />
    @if (comment is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@comment.Name</dd>
            <dt class="col-sm-2">Email</dt>
            <dd class="col-sm-10">@comment.Email</dd>
            <dt class="col-sm-2">ProductId</dt>
            <dd class="col-sm-10">@comment.ProductId</dd>
            <dt class="col-sm-2">CommentText</dt>
            <dd class="col-sm-10">@comment.CommentText</dd>
            <dt class="col-sm-2">CreateDate</dt>
            <dd class="col-sm-10">@comment.CreateDate</dd>
        </dl>
        <div>
            <a href="@($"/comments/edit?id={comment.Id}")">Edit</a> |
            <a href="@($"/comments")">Back to List</a>
        </div>
    }
</div>

@code {
    private Comment? comment;

    [SupplyParameterFromQuery]
    private int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        comment = await GetCommentByIdUseCase .ExecuteAsync(Id);

        if (comment is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }
}
