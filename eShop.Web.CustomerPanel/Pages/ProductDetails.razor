<!--breadcrumbs area end-->
<!--product details start-->
<section class="product_details mb-135" style="margin-top:150px;">
    <div class="container">
        <div class="row">
            <div class="col-lg-6 col-md-6">
                <div class="product_zoom_gallery">
                    <ProductDetailsImageSlider Galleries="@Galleries" ImageName="@Product.ImageName" />
                </div>
            </div>
            <div class="col-lg-6 col-md-6">
                <div class="product_d_right">
                    <form action="#">
                        <h1>@Product.Title</h1>
                        <div class="product_ratting_review d-flex align-items-center">

                           @*  <div class="product_review">
                                <ul class="d-flex">
                                    <li>@CommentsCount نظر</li>
                                    <li>نوشتن نظر</li>
                                </ul>
                            </div> *@
                        </div>
                        @if (Product.Discount!=null && Product.Discount!=0)
                        {
                            <div class="price_box">
                                @{
                                    decimal? discountAmount = Product.Price.GetValueOrDefault(0) - Product.Discount.GetValueOrDefault(0);
                                }
                                <span class="current_price">@discountAmount.GetValueOrDefault(0).ToString("N0") تومان</span>
                                <span class="old_price">@Product.Price.GetValueOrDefault(0).ToString("N0") تومان</span>
                            </div>
                        }
                        else
                        {
                            <div class="price_box">
                                <span class="price">@Product.Price.GetValueOrDefault(0).ToString("N0") تومان</span>
                            </div>
                        }
                        <div class="product_availalbe">
                            <ul class="d-flex">
                                @* <li><i class="icon-layers icons"></i> فقط <span>@Product.Qty</span> باقی مانده </li> *@
                                @if (Product.Qty>0)
                                {
                                    <li>موجود است : <span class="stock">@Product.Qty عدد باقی مانده در انبار </span>
                                
                                    </li>
                                }
                                else
                                {
                                    <li><span class="text-danger">موجود نمی‌باشد</span></li>
                                }
                            </ul>
                        </div>
                        <div class="product_desc">
                            <p>@Product.Description</p>
                        </div>
                        <div class="product_variant">
                            <div class="variant_quantity_btn d-flex">
                                @if (Product.Qty>0)
                                {
                                    @* <button  class="button btn btn-primary" type="submit">افزودن به سبد ‌خرید</button> *@
                                    <AddToCartComponent ProductId="@Product.Id" />
                                }
                            </div>
                        </div>
                        <div class="product_sku">
                            <p><span>کد کالا: </span>#PRO @Product.Id</p>
                        </div>
                        @if (!string.IsNullOrEmpty(Product.Tags))
                        {
                            <div class="product_tags d-flex">
                                <span> تگ ها : </span>
                                @{
                                    var tags = Product.Tags.Split(",");
                                }
                                @foreach (var item in tags)
                                {

                                    <ul class="d-flex">
                                        <li>
                                            @* <a href="/shop?searchText=fashion=@item"> *@
                                            @item,
                                            @* </a> *@
                                            </li>
                                    </ul>
                                }
                            </div>
                        }
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
<!--product details end-->
<!--product info start-->
<div class="product_d_info mb-118">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="product_d_inner">
                    <div class="product_info_button border-bottom">
                       <ProductDetailsTabComponent Product="Product" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!--product info end-->
<!--product area start-->
@* <section class="product_area related_products mb-118">
