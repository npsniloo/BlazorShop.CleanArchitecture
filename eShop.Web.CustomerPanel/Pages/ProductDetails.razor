@page "/product/{id:int}"
@inject IGetProductDetailsUseCase  GetProductDetailsUseCase
@inject IGetGalleriesByProdIdUseCase GetGalleriesByProdIdUseCase
@inject IGetCommentsCountUseCase GetCommentsCount
@inject NavigationManager NavigationManager


<!--breadcrumbs area start-->
