                    <h2>New Products</h2>
                </div>
            </div>
        </div>
        <div class="product_container row">
            <NewProductsComponent />
        </div>
    </div>
</section> *@
<!--product area end-->
@code {

    [SupplyParameterFromQuery]
    public int Id{ get; set; }
    private Product? Product { get; set; } = new();
    private List<ProductGallery> Galleries { get; set; } = new();
    private int CommentsCount{ get; set; }
    protected async override Task OnInitializedAsync()
    {
        Product = await GetProductDetailsUseCase.ExecuteAsync(Id);
        if (Product == null)
        {
            NavigationManager.NavigateTo("not found");
        }
        Galleries = (await GetGalleriesByProdIdUseCase.ExecuteAsync(Product!.Id)).ToList();
        //------------------------------------
        CommentsCount = await GetCommentsCount.ExecuteAsync(Product!.Id);
    }
}
