@inject IViewBestSellingProducts ViewBestSellingProducts


@if (BestSellingProducts.Count>0)
{
    <section class="product_section mb-96">
        <div class="container">
            <div class="product_header d-flex justify-content-between  mb-50">
                <div class="section_title">
                    <h2>best selling items</h2>
                </div>
            </div>
            <div class="product_container row">
                <div class="tab-content">
                    <div class="tab-pane fade show active" id="all" role="tabpanel">
                        <Carousel>
                            @if (BestSellingProducts.Any())
                            {
                                var numberOfRows = Math.Ceiling((decimal)((decimal)BestSellingProducts.Count / 4));
                                bool active = true;
                                for (int i = 0; i < numberOfRows; i++)
                                {
                                    var productsToDisplay = BestSellingProducts.Skip(i*4).Take(4);
                                    <CarouselItem Active="active">
                                        <div class="row">
                                            @foreach (var item in productsToDisplay)
                                            {
                                                var product = new Product
                                                {
                                                    Id = item.ProductId,
                                                    Title = item.Title,
                                                    Discount = item.Discount,
                                                    ImageName = item.ImageName,
                                                    Price = item.Price,
                                                    Qty = item.Qty
                                                };

                                                <div class="col-6 col-md-3 single_product">
                                                    <ProductBoxComponent Model="product" />
                                                </div>
                                            }
                                        </div>
                                    </CarouselItem>
                                }



                            }
                        </Carousel>
                    </div>
                </div>
            </div>
        </div>
    </section>
}
@code {
    public List<BestSellingProduct> BestSellingProducts { get; set; } = new();
   
    protected async override Task OnAfterRenderAsync(bool firstRender)
    {
        BestSellingProducts = await ViewBestSellingProducts.ExecuteAsync(8);
    }
}