@inject IShowSecondBannersUseCase ShowSecondBanners
<section class="banner_section banner_style2 mb-109">
    <div class="container-fluid">
        <div class="row">
            @foreach (var item in Banners)
            {
                <div class="col-lg-6 col-md-6 col-sm-6">
                    <figure class="single_banner position-relative">
                        <img src="/images/banners/@item.ImageName" alt="@item.Title">
                        <div class="banner_text position-absolute">
                            <h3>@((MarkupString)(item.Title?.Replace("\n", "<br/>")))</h3>
                            <p>@((MarkupString)(item.SubTitle?.Replace("\n", "<br/>")))</p>
                            @if (!string.IsNullOrEmpty(item.Link))
                            {
                                <a class="btn btn-primary" href="@item.Link">Shop Now</a>
                            }
                        </div>
                        <div class="banner_tag">
                            <span>new arrivals <br> women</span>
                        </div>
                    </figure>
                </div>
            }

        </div>
    </div>
</section>

@code {
    public List<Banner> Banners { get; set; } = new();


    protected async override Task OnAfterRenderAsync(bool firstRender)
    {
        Banners = await ShowSecondBanners.ExecuteAsync();
    }
}
