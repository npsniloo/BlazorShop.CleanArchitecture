@page "/resetpassword"
@inject IResetPasswordHandler resetPasswordHandler
@inject NavigationManager NavigationManager
@inject IValidator<ResetPasswordViewModel> Validator
@rendermode InteractiveServer

<PageTitle>ResetPassword</PageTitle>


<hr />
<div class="row" style="margin-top:150px">
    <div class="col-md-4 mx-auto border">
        <EditForm method="post" Model="ResetPasswordModel" OnValidSubmit="HandleValidSubmit" FormName="login" Enhance>
            <FluentValidationValidator Validator="Validator" />
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger" role=alert>
                    @errorMessage
                </div>
            }
            <div class="mb-3">
                <label for="email" class="form-label">ایمیل:</label>
                <InputText id="email" @bind-Value="ResetPasswordModel.Email" class="form-control" />
                <ValidationMessage For="() => ResetPasswordModel.Email" class="text-danger" />
            </div>
            <div class="mb-3">
                <label for="newpassword" class="form-label">رمزعبور جدید:</label>
                <input id="newpassword"  type="password" @bind="ResetPasswordModel.NewPassword" class="form-control" />

                <ValidationMessage For="() => ResetPasswordModel.NewPassword" class="text-danger" />
            </div>
            <div class="mb-3">
                <label for="recovercode" class="form-label">کد بازیابی:</label>
                <InputNumber id="recovercode" @bind-Value="ResetPasswordModel.RecoveryCode" class="form-control" />
                <ValidationMessage For="() => ResetPasswordModel.RecoveryCode" class="text-danger" />
            </div>
            <button type="submit" class="btn btn-primary" disabled="@(loading ? "disabled" : null)">
                @if (loading)
                {
                    <Spinner Class="me-3" Type="SpinnerType.Dots" Color="SpinnerColor.Light" />

                }
                else
                {
                    <span>
                        تغییر رمز عبور
                    </span>
                }
            </button>
        </EditForm>
        <br />
        <div>
            <a href="/register">میخواهید حساب بسازید؟ ثبت نام</a>
        </div>
    </div>
</div>


@code {
    [SupplyParameterFromForm]
    private ResetPasswordViewModel ResetPasswordModel { get; set; } = new();
    private string? errorMessage = null;
    private bool loading = false;
    private async Task HandleValidSubmit()
    {
        loading = true;
        await Task.Delay(1500);
        //--------------------------------------------------
        try{
            var command = new ResetPasswordCommand(ResetPasswordModel.Email, ResetPasswordModel.NewPassword, ResetPasswordModel.RecoveryCode);
            await resetPasswordHandler.ExecuteAsync(command);
            loading = false;
            NavigationManager.NavigateTo("/login");
        }
        catch
        {
            errorMessage = "تغییر رمزعبور با خطا مواجه شد.";
            loading = false;
            return;
        }

    }
}
